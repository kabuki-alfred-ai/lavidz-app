generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Theme {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  introduction   String?
  active         Boolean       @default(true)
  order          Int           @default(0)
  brandName      String?
  brandColor     String?       @default("#FF4D1C")
  logoUrl        String?
  questions      Question[]
  sessions       Session[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Question {
  id         String      @id @default(cuid())
  themeId    String
  theme      Theme       @relation(fields: [themeId], references: [id], onDelete: Cascade)
  text       String
  hint       String?
  order      Int
  active     Boolean     @default(true)
  recordings Recording[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Session {
  id              String              @id @default(cuid())
  themeId         String
  theme           Theme               @relation(fields: [themeId], references: [id])
  status          SessionStatus       @default(PENDING)
  recipientEmail  String?
  recipientName   String?
  version         Int                 @default(1)
  finalVideoKey   String?
  montageSettings Json?
  submittedAt     DateTime?
  deliveredAt     DateTime?
  recordings      Recording[]
  memories        ConversationMemory[]
  feedback        Feedback?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Recording {
  id                String          @id @default(cuid())
  sessionId         String
  session           Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question        @relation(fields: [questionId], references: [id])
  rawVideoKey       String?
  finalVideoKey     String?
  transcript        String?
  wordTimestamps    Json?
  ttsAudioKey       String?
  ttsVoiceId        String?
  processedVideoKey String?
  processingHash    String?
  status            RecordingStatus @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  status             OrgStatus            @default(PENDING)
  users              User[]
  themes             Theme[]
  entrepreneurProfile EntrepreneurProfile?
  orgInvitations     OrgInvitation[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  passwordHash         String
  firstName            String?
  lastName             String?
  role                 UserRole          @default(USER)
  avatarKey            String?
  organizationId       String?
  organization         Organization?     @relation(fields: [organizationId], references: [id])
  sentInvitations      AdminInvitation[]
  sentOrgInvitations   OrgInvitation[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

enum SessionStatus {
  PENDING
  RECORDING
  SUBMITTED
  PROCESSING
  DONE
  FAILED
}

enum RecordingStatus {
  PENDING
  TRANSCRIBING
  DONE
  FAILED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model AdminInvitation {
  id          String           @id @default(cuid())
  email       String           @unique
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(PENDING)
  invitedById String?
  invitedBy   User?            @relation(fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum OwnerType {
  ORGANIZATION
  USER
}

enum SoundTag {
  TRANSITION
  INTRO
  OUTRO
  BACKGROUND
}

model SoundAsset {
  id        String   @id @default(cuid())
  name      String
  tag       SoundTag
  fileKey   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EntrepreneurProfile {
  id                 String               @id @default(cuid())
  organizationId     String?              @unique
  userId             String?              @unique
  ownerType          OwnerType            @default(ORGANIZATION)
  businessContext    Json                 @default("{}")
  topicsExplored     String[]             @default([])
  communicationStyle String?
  linkedinUrl        String?
  linkedinIngestedAt DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  organization       Organization?        @relation(fields: [organizationId], references: [id])
  memories           ConversationMemory[]
}

model Feedback {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallRating   Int      // 1-5 stars
  questionRating  Int      // 1-5 stars — quality of questions
  comment         String?
  createdAt       DateTime @default(now())
}

model ConversationMemory {
  id        String              @id @default(cuid())
  profileId String
  sessionId String?
  content   String
  embedding Unsupported("vector(768)")
  tags      String[]            @default([])
  createdAt DateTime            @default(now())
  profile   EntrepreneurProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  session   Session?            @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}

model OrgInvitation {
  id             String           @id @default(cuid())
  email          String
  token          String           @unique @default(cuid())
  status         InvitationStatus @default(PENDING)
  role           UserRole         @default(USER)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  invitedById    String?
  invitedBy      User?            @relation(fields: [invitedById], references: [id])
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([email, organizationId])
}
