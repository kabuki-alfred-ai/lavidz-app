generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Theme {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  introduction   String?
  active         Boolean       @default(true)
  order          Int           @default(0)
  brandName      String?
  brandColor     String?       @default("#FF4D1C")
  logoUrl        String?
  questions      Question[]
  sessions       Session[]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Question {
  id         String      @id @default(cuid())
  themeId    String
  theme      Theme       @relation(fields: [themeId], references: [id], onDelete: Cascade)
  text       String
  hint       String?
  order      Int
  active     Boolean     @default(true)
  recordings Recording[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Session {
  id                 String               @id @default(cuid())
  themeId            String
  theme              Theme                @relation(fields: [themeId], references: [id])
  status             SessionStatus        @default(PENDING)
  contentFormat      ContentFormat?
  targetPlatforms    String[]             @default([])
  teleprompterScript String?
  recipientEmail     String?
  recipientName      String?
  version            Int                  @default(1)
  finalVideoKey      String?
  montageSettings    Json?
  submittedAt        DateTime?
  deliveredAt        DateTime?
  publishedAt        DateTime? // cochée par l'entrepreneur quand son contenu est en ligne
  topicId            String?
  topicEntity        Topic?               @relation(fields: [topicId], references: [id], onDelete: SetNull)
  recordingScript    Json?                // format-specific polymorphe (6 kinds) + anchorSyncedAt — cf. apps/web/src/lib/recording-script.ts
  hooks              Json?                // { native, marketing, chosen?, generatedAt } format-specific
  lastActivityAt     DateTime?            // updated à chaque take fini — source du banner reprise Kabou
  recordings         Recording[]
  memories           ConversationMemory[]
  feedback           Feedback?
  generatedPosts     GeneratedPost[]
  analysis           RecordingAnalysis?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

enum RecordingAnalysisStatus {
  PENDING
  READY
  FAILED
}

model RecordingAnalysis {
  id                String                  @id @default(cuid())
  sessionId         String                  @unique
  session           Session                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status            RecordingAnalysisStatus @default(PENDING)
  // Summary of what the entrepreneur said (array of bullet-point strings)
  summary           Json?
  // A single standout quote or moment extracted from the takes
  standoutMoment    String?
  // What worked well (array of strings, max 3)
  strengths         Json?
  // Improvement paths (max 2) — each { path, reason, actionType: 'redo'|'montage_hint'|'none', targetQuestionId?, montageHint? }
  improvementPaths  Json?
  // Raw computed stats — fillers count, silences, avg sentence length, etc.
  stats             Json?
  errorMessage      String?
  generatedAt       DateTime?
  regeneratedAt     DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model Recording {
  id                  String          @id @default(cuid())
  sessionId           String
  session             Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId          String
  question            Question        @relation(fields: [questionId], references: [id])
  rawVideoKey         String?
  finalVideoKey       String?
  transcript          String?
  wordTimestamps      Json?
  ttsAudioKey         String?
  ttsVoiceId          String?
  processedVideoKey   String?
  processingHash      String?
  status              RecordingStatus @default(PENDING)
  supersededAt        DateTime?       // set quand un retake canonique sur le même questionId est créé (F10)
  kabouRecommendation Json?           // { score, reason, criteria: { tempo, clarity, energy, tone } }
  projectClips        ProjectClip[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  status              OrgStatus            @default(PENDING)
  users               User[]
  themes              Theme[]
  entrepreneurProfile EntrepreneurProfile?
  orgInvitations      OrgInvitation[]
  brandKit            BrandKit?
  brolls              BRoll[]
  calendarEntries     ContentCalendar[]
  topics              Topic[]
  compositions        Composition[]
  projects            Project[]
  generatedPosts      GeneratedPost[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String
  firstName          String?
  lastName           String?
  role               UserRole          @default(USER)
  avatarKey          String?
  organizationId     String?
  organization       Organization?     @relation(fields: [organizationId], references: [id])
  sentInvitations    AdminInvitation[]
  sentOrgInvitations OrgInvitation[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

enum SessionStatus {
  PENDING
  RECORDING
  SUBMITTED
  PROCESSING
  DONE
  LIVE     // sticky — publishedAt renseigné
  REPLACED // variante remplacée (auto-set quand "Tenter un autre angle")
  FAILED
}

enum RecordingStatus {
  PENDING
  TRANSCRIBING
  DONE
  FAILED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model AdminInvitation {
  id          String           @id @default(cuid())
  email       String           @unique
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(PENDING)
  invitedById String?
  invitedBy   User?            @relation(fields: [invitedById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum OwnerType {
  ORGANIZATION
  USER
}

enum SoundTag {
  TRANSITION
  INTRO
  OUTRO
  BACKGROUND
}

model SoundAsset {
  id        String   @id @default(cuid())
  name      String
  tag       SoundTag
  fileKey   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EntrepreneurProfile {
  id                 String               @id @default(cuid())
  organizationId     String?              @unique
  userId             String?              @unique
  ownerType          OwnerType            @default(ORGANIZATION)
  businessContext    Json                 @default("{}")
  topicsExplored     String[]             @default([])
  communicationStyle String?
  linkedinUrl        String?
  linkedinIngestedAt DateTime?
  websiteUrl         String?
  websiteIngestedAt  DateTime?
  editorialPillars   String[]             @default([])
  editorialTone      String?
  targetFrequency    Int?
  targetPlatforms    String[]             @default([])
  editorialValidated Boolean              @default(false)
  thesis             Json?                // { statement: string, enemies: string[], audienceArchetype: string, confidence: 'forming'|'emerging'|'crystallized', updatedAt: string }
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  organization       Organization?        @relation(fields: [organizationId], references: [id])
  memories           ConversationMemory[]
}

model Feedback {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallRating  Int // 1-5 stars
  questionRating Int // 1-5 stars — quality of questions
  comment        String?
  createdAt      DateTime @default(now())
}

model ConversationMemory {
  id        String                     @id @default(cuid())
  profileId String
  sessionId String?
  topicId   String?                    // scope topic-level pour RAG
  content   String
  embedding Unsupported("vector(768)")
  tags      String[]                   @default([])
  createdAt DateTime                   @default(now())
  profile   EntrepreneurProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  session   Session?                   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  topic     Topic?                     @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@index([profileId, topicId])
}

model OrgInvitation {
  id             String           @id @default(cuid())
  email          String
  token          String           @unique @default(cuid())
  status         InvitationStatus @default(PENDING)
  role           UserRole         @default(USER)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  invitedById    String?
  invitedBy      User?            @relation(fields: [invitedById], references: [id])
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([email, organizationId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  organizationId String
  threadId       String   @default(cuid())
  role           String // 'user' | 'assistant' | 'system' | 'tool'
  content        String
  toolCalls      Json?
  toolResults    Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, threadId, createdAt])
}

// ============================================
// Personal Branding V1 — New Models
// ============================================

model BrandKit {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryColor   String       @default("#FF4D1C")
  secondaryColor String       @default("#1A1A2E")
  accentColor    String       @default("#E94560")
  fontTitle      String       @default("Inter")
  fontBody       String       @default("Inter")
  logoUrl        String?
  introVideoUrl  String?
  outroVideoUrl  String?
  watermark      Json? // { position, opacity, size }
  voiceTone      VoiceTone    @default(PROFESSIONAL)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum VoiceTone {
  PROFESSIONAL
  CASUAL
  EXPERT
  ENERGETIC
  INSPIRATIONAL
}

enum BRollSource {
  USER
  PEXELS
  UNSPLASH
}

model BRoll {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source         BRollSource
  url            String
  thumbnailUrl   String?
  tags           String[]     @default([])
  duration       Float? // duration in seconds
  title          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([tags])
}

enum ContentFormat {
  QUESTION_BOX
  TELEPROMPTER
  HOT_TAKE
  STORYTELLING
  DAILY_TIP
  MYTH_VS_REALITY
}

enum ContentCalendarStatus {
  PLANNED
  RECORDED
  EDITING
  DELIVERED
  PUBLISHED
  SKIPPED
}

enum TopicStatus {
  DRAFT
  READY
  ARCHIVED
}

model Topic {
  id              String                @id @default(cuid())
  organizationId  String
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  brief           String?               // AI-generated summary, enriched over conversations
  status          TopicStatus           @default(DRAFT)
  threadId        String                @unique @default(cuid()) // dedicated chat thread
  pillar          String?               // linked editorial pillar
  hooks           Json?                 // LEGACY dual-write — drop sprint+1
  hookDraft       Json?                 // notes libres d'idées d'accroches (texte libre, pas structuré)
  sources         Json?                 // [{ title, url, summary, relevance, fetchedAt }] — anchors HOT_TAKE / fact-heavy sujets
  recordingGuide  Json?                 // LEGACY dual-write — drop sprint+1
  narrativeAnchor Json?                 // { kind: 'draft', bullets: string[], updatedAt: string } — cf. apps/web/src/lib/narrative-anchor.ts
  calendarEntries ContentCalendar[]
  sessions        Session[]
  generatedPosts  GeneratedPost[]
  memories        ConversationMemory[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model ContentCalendar {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scheduledDate  DateTime // legacy — prefer publishAt for new flows
  publishAt      DateTime? // target publication date, null when not planned
  description    String?
  format         ContentFormat
  platforms      String[]              @default([]) // ["linkedin", "tiktok", "instagram", "youtube"]
  status         ContentCalendarStatus @default(PLANNED)
  sessionId      String? // linked to session once recorded
  topicId        String // le Sujet est l'atome — chaque entrée du calendrier EST un Sujet planifié
  topicEntity    Topic                 @relation(fields: [topicId], references: [id], onDelete: Cascade)
  aiSuggestions  Json? // { hook, questions, script, angle }
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
  @@index([scheduledDate])
  @@index([publishAt])
  @@index([topicId])
}

enum ProjectStatus {
  DRAFT
  EDITING
  RENDERING
  DONE
  FAILED
}

model Project {
  id             String        @id @default(cuid())
  title          String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         ProjectStatus @default(DRAFT)
  montageSettings Json?
  sessionId      String?       @unique // source session (auto-created projects) — @unique pour idempotence F5
  clips          ProjectClip[]
  compositions   Composition[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model ProjectClip {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  order       Int
  visibleRanges Json?   // per-clip trim overrides for this project

  @@unique([projectId, recordingId])
  @@index([projectId])
}

enum CompositionStatus {
  DRAFT
  RENDERING
  DONE
  FAILED
}

model Composition {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessionId       String?
  projectId       String?
  project         Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title           String?
  platform        String? // target platform: linkedin, tiktok, instagram, youtube
  aspectRatio     String            @default("9:16") // 9:16, 1:1, 16:9, 4:5
  timeline        Json? // full timeline structure for Remotion
  brollPlacements Json? // [{ brollId, startTime, duration, position }]
  brandKitApplied Boolean           @default(true)
  status          CompositionStatus @default(DRAFT)
  outputUrl       String? // final rendered video URL/key
  renderJobId     String? // BullMQ job reference
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId])
  @@index([sessionId])
}

// ---------------------------------------------------------------------------
// Generated social posts (LinkedIn today, extensible to X / Threads later)
// A post is always anchored to either a Topic OR a Session (exclusive).
// ---------------------------------------------------------------------------

enum GeneratedPostPlatform {
  LINKEDIN
  X
  THREADS
}

enum GeneratedPostStatus {
  DRAFT
  READY
  PUBLISHED
}

enum GeneratedPostVariant {
  SHORT
  LONG
  STORY
}

model GeneratedPost {
  id             String                @id @default(cuid())
  organizationId String
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform       GeneratedPostPlatform @default(LINKEDIN)
  variant        GeneratedPostVariant  @default(LONG)
  content        String                @db.Text
  status         GeneratedPostStatus   @default(DRAFT)
  topicId        String?
  topic          Topic?                @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sessionId      String?
  session        Session?              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId])
  @@index([topicId])
  @@index([sessionId])
}
