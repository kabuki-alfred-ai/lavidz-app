{
  "name": "lavidz",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @lavidz/database run db:generate",
    "db:migrate": "pnpm --filter @lavidz/database run db:migrate",
    "db:studio": "pnpm --filter @lavidz/database run db:studio",
    "db:seed": "pnpm --filter @lavidz/database run db:seed",
    "create-superadmin": "pnpm --filter @lavidz/database run create-superadmin"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2"
  }
}
